APP_ENV=development
LOG_LEVEL=INFO
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=change_me
DB_PASSWORD=change_me
DB_NAME=system_monitoring
API_BASE_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175,http://localhost:5173,http://localhost:5174,http://localhost:5175
STRICT_CORS_IN_NON_DEV=true
JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_ROLE=admin
ZSCORE_THRESHOLD=1.5
ZSCORE_WINDOW_SIZE=30
ZSCORE_MIN_POINTS=10
ALERT_COOLDOWN_MINUTES=15
